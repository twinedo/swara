{
  "name": "swara",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check": "turbo run check",
    "migrate": "turbo run migrate",
    "migrate:revert": "turbo run migrate:revert",
    "api:build:release": "cargo build --release -p swara-api",
    "api:check": "cargo check -p swara-api",
    "api:clippy": "cargo clippy -p swara-api -- -D warnings",
    "api:dev:local": "./scripts/run-api-local.sh",
    "api:fmt": "cargo fmt -p swara-api",
    "api:local:start": "./scripts/start-local-stack.sh",
    "api:local:status": "./scripts/status-local-stack.sh",
    "api:local:stop": "./scripts/stop-local-stack.sh",
    "api:test": "cargo test -p swara-api",
    "prepare": "sqlx prepare --workspace"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ]
}
